
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq50xx=y
CONFIG_TARGET_qualcommax_ipq50xx_generic=y
CONFIG_TARGET_PROFILE="xunison_exigo_hub_d50_5g"

CONFIG_KERNEL_PATCHVER=5.15
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y

CONFIG_PACKAGE_kmod-ath11k-pci=y
CONFIG_PACKAGE_ath11k-firmware-ipq5018=y
CONFIG_PACKAGE_ath11k-firmware-qcn9074=y
CONFIG_PACKAGE_kmod-cfg80211=y
CONFIG_PACKAGE_kmod-mac80211=y

CONFIG_PACKAGE_kmod-pcie-mhi=y
CONFIG_PACKAGE_kmod-qrtr=y
CONFIG_PACKAGE_kmod-qrtr-mhi=y
CONFIG_PACKAGE_kmod-qcom-qmi-helpers=y
CONFIG_PACKAGE_kmod-rmnet-core=y
CONFIG_PACKAGE_kmod-rmnet-ctl=y
CONFIG_PACKAGE_kmod-rmnet-nss=y

CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-wwan=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-usb-serial-qualcomm=y

CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-dwc3=y
CONFIG_PACKAGE_kmod-usb-dwc3-qcom=y

CONFIG_PACKAGE_qmodem=y
CONFIG_PACKAGE_qmodem-utils=y
CONFIG_PACKAGE_qmodem-nr=y
CONFIG_PACKAGE_qmodem-lte=y
CONFIG_PACKAGE_qmodem-lock=y
CONFIG_PACKAGE_qmodem-diag=y
CONFIG_PACKAGE_qmodem-signal=y
CONFIG_PACKAGE_qmodem-stats=y
CONFIG_PACKAGE_luci-app-qmodem=y
CONFIG_PACKAGE_luci-app-qmodem-sms=y
CONFIG_PACKAGE_luci-app-qmodem-ttl=y

CONFIG_PACKAGE_kmod-qcom-wdt=y
CONFIG_PACKAGE_watchcat=y
CONFIG_PACKAGE_luci-app-watchcat=y

CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-mod-dashboard=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-compat=y

CONFIG_PACKAGE_kmod-nf-nat=y
CONFIG_PACKAGE_kmod-nf-conntrack=y
CONFIG_PACKAGE_kmod-nf-flow=y
CONFIG_PACKAGE_kmod-ipt-core=y
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_kmod-ipt-conntrack=y
CONFIG_PACKAGE_kmod-ipt-ipset=y
CONFIG_PACKAGE_ipset=y

CONFIG_PACKAGE_wpad-basic-mbedtls=y

CONFIG_PACKAGE_kmod-leds-gpio=y
CONFIG_PACKAGE_kmod-gpio-button-hotplug=y
CONFIG_PACKAGE_kmod-input-gpio-keys=y

CONFIG_PACKAGE_kmod-qca-nss-dp=y
CONFIG_PACKAGE_kmod-qca-nss-drv=y
CONFIG_PACKAGE_kmod-qca-nss-ecm-premium=y

